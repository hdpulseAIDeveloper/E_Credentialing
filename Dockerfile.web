# ESSEN Credentialing Platform — Web Container (Development)
# Next.js App Router: UI + tRPC API + Auth.js + Socket.io
# Hot reload enabled via volume mounts in docker-compose.dev.yml

FROM node:20-alpine

WORKDIR /app

# Install dependencies for Prisma and native modules
RUN apk add --no-cache libc6-compat openssl

# Copy package files
COPY package*.json ./
# Copy prisma schema BEFORE npm install so the `postinstall: prisma generate`
# hook in package.json can find prisma/schema.prisma. Without this, the
# postinstall fails with "Could not find Prisma Schema". The explicit
# `npx prisma generate` below is left as a belt-and-suspenders step that
# matches Dockerfile.web.prod's builder stage.
COPY prisma ./prisma
RUN npm install --legacy-peer-deps

# Re-run prisma generate explicitly (no-op after the postinstall above,
# but kept for parity with Dockerfile.web.prod).
RUN npx prisma generate

# Copy source (overridden by volume mounts in dev)
COPY . .

# Expose Next.js dev server port
EXPOSE 6015

ENV HOSTNAME="0.0.0.0"
ENV PORT=6015
ENV NEXT_TELEMETRY_DISABLED=1
# Enable polling for file watching inside Docker on Windows
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true

# `dev:warm` runs `next dev` and spawns the route pre-warmer once the
# server is accepting connections. This eliminates the "every link
# feels slow the first time" experience caused by Next's lazy
# per-route compilation in dev mode (see DEF-INFRA-0001 and
# scripts/dev/dev-with-warmup.mjs). To opt out, set SKIP_WARMUP=1.
CMD ["npm", "run", "dev:warm"]
