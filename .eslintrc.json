{
  "extends": "next/core-web-vitals",
  "plugins": ["@typescript-eslint", "ecred-local"],
  "rules": {
    "@next/next/no-html-link-for-pages": "off",
    "@next/next/no-before-interactive-script-outside-document": "off",
    "react/no-unescaped-entities": "off",
    "react-hooks/exhaustive-deps": "warn",
    "@typescript-eslint/no-explicit-any": "off"
  },
  "overrides": [
    {
      "files": [
        "src/app/**/*.{ts,tsx}",
        "src/components/**/*.{ts,tsx}"
      ],
      "excludedFiles": [
        "src/lib/email/**",
        "src/workers/**",
        "src/server/**",
        "**/*.email.ts",
        "**/*.email.tsx"
      ],
      "rules": {
        "ecred-local/no-raw-color": "error"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "tests/**",
    "prisma/migrations/**",
    "src/app/api/trpc/**",
    "scripts/**",
    "eslint-rules/**",
    "stories/**"
  ]
}

