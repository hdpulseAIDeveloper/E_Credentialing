  lastSubmittedAt  DateTime? @map("last_submitted_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // ── P1 Gap #13: per-payer SFTP delivery configuration ──────────────────
  // Credentials are referenced by Azure Key Vault secret name, never stored
  // in the DB directly. host/port/username/paths are non-secret and live here.
  sftpHost              String? @map("sftp_host")
  sftpPort              Int?    @map("sftp_port")
  sftpUsername          String? @map("sftp_username")
  // Vault secret names — looked up at runtime by the SFTP client.
  sftpPasswordSecretRef String? @map("sftp_password_secret_ref")
  sftpPrivateKeySecretRef String? @map("sftp_private_key_secret_ref")
  // Remote directory layout.
  sftpUploadDir         String? @map("sftp_upload_dir")
  sftpAckDir            String? @map("sftp_ack_dir")
  // Glob/regex used to match the ack file back to a submission.
  // Supported placeholders: {basename}, {YYYYMMDD}.
  sftpAckPattern        String? @map("sftp_ack_pattern")
  sftpHostKeyFingerprint String? @map("sftp_host_key_fingerprint")
  sftpEnabled           Boolean @default(false) @map("sftp_enabled")

  submissions RosterSubmission[] @relation("RosterSubmissions")

  @@map("payer_rosters")
}

model RosterSubmission {
  id               String       @id @default(uuid())
  rosterId         String       @map("roster_id")
  status           RosterStatus @default(DRAFT)
  providerCount    Int          @default(0) @map("provider_count")
  blobUrl          String?      @map("blob_url")
  validationErrors Json?        @map("validation_errors")
  submittedAt      DateTime?    @map("submitted_at")
  submittedBy      String?      @map("submitted_by")
  acknowledgedAt   DateTime?    @map("acknowledged_at")
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // ── P1 Gap #13: real-SFTP delivery + ack tracking ──────────────────────
  remoteFilename   String?  @map("remote_filename")
  remotePath       String?  @map("remote_path")
  remoteSize       Int?     @map("remote_size")
  ackFilename      String?  @map("ack_filename")
