  // jobs (caqh-reattestation, telehealth-compliance, supervision-
  // reminder). Added so those nightly sweeps can exclude providers who
  // have left the organization or withdrew their application.
  TERMINATED
  WITHDRAWN
}

enum LicenseStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
