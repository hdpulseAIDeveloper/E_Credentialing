generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  PROVIDER
  SPECIALIST
  MANAGER
  COMMITTEE_MEMBER
  ADMIN
}

