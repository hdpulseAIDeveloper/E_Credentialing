enum MedicaidAffiliationStatus {
  PENDING
  IN_PROCESS
  ENROLLED
  REVALIDATION_DUE
  EXPIRED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  displayName             String    @map("display_name")
  role                    UserRole
  passwordHash            String?   @map("password_hash")
  azureAdOid              String?   @unique @map("azure_ad_oid")
  providerId              String?   @map("provider_id")
  isActive                Boolean   @default(true) @map("is_active")
  lastLoginAt             DateTime? @map("last_login_at")
  notificationPreferences Json?     @map("notification_preferences")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  // Relations
  linkedProvider         Provider?          @relation("UserLinkedProvider", fields: [providerId], references: [id])
  assignedProviders      Provider[]         @relation("SpecialistAssignedProviders")
  approvedProviders      Provider[]         @relation("ApprovedByUser")
  triggeredBotRuns       BotRun[]           @relation("BotRunTriggeredBy")
  assignedTasks          Task[]             @relation("TaskAssignedTo")
  completedTasks         Task[]             @relation("TaskCompletedBy")
  taskComments           TaskComment[]      @relation("TaskCommentAuthor")
  communications         Communication[]    @relation("CommunicationFromUser")
  flaggedChecklist       ChecklistItem[]    @relation("ChecklistFlaggedBy")
  acknowledgedSanctions  SanctionsCheck[]   @relation("SanctionsAcknowledgedBy")
  acknowledgedNpdb       NPDBRecord[]       @relation("NpdbAcknowledgedBy")
  acknowledgedVerif      VerificationRecord[] @relation("VerifAcknowledgedBy")
  committeeDecisions     CommitteeProvider[] @relation("CommitteeDecisionBy")
  enrollmentSubmissions  Enrollment[]       @relation("EnrollmentSubmittedBy")
  enrollmentAssignments  Enrollment[]       @relation("EnrollmentAssignedTo")
  enrollmentFollowUps    EnrollmentFollowUp[] @relation("FollowUpPerformedBy")
  uploadedDocuments      Document[]         @relation("DocumentUploadedBy")
  auditLogsAsActor       AuditLog[]         @relation("AuditLogActor")
  sanctionsTriggered     SanctionsCheck[]   @relation("SanctionsTriggeredByUser")
  hospitalSubmissions    HospitalPrivilege[] @relation("HospitalSubmittedBy")
  createdWorkflows       Workflow[]          @relation("WorkflowCreator")
  medicaidEnrollmentsCreated MedicaidEnrollment[] @relation("MedicaidCreatedBy")
  savedReports           SavedReport[]       @relation("SavedReportCreator")
  evaluationsAsEvaluator PracticeEvaluation[] @relation("EvaluationEvaluator")
  peerReviewMeetingsLed  PeerReviewMeeting[]  @relation("PeerReviewChair")
  peerReviewMinutesAuthored PeerReviewMinute[] @relation("PeerReviewMinuteAuthor")
  trainingRecords        StaffTrainingRecord[] @relation("UserTrainingRecords")
  trainingAssignments    TrainingAssignment[]  @relation("TrainingAssignmentUser")
  aiModelCardsReviewed   AiModelCard[]         @relation("AiModelCardReviewer")
  aiDecisionsHuman       AiDecisionLog[]       @relation("AiDecisionLogHuman")
  botExceptionVerdictsResolved BotExceptionVerdict[] @relation("BotExceptionVerdictResolvedBy")
  ncqaAssessments        NcqaCriterionAssessment[] @relation("NcqaAssessments")
  ncqaSnapshots          NcqaComplianceSnapshot[]  @relation("NcqaSnapshots")
  monitoringAlertsAck    MonitoringAlert[]         @relation("MonitoringAlertAcknowledgedBy")
  monitoringAlertsRes    MonitoringAlert[]         @relation("MonitoringAlertResolvedBy")
  aiConversations        AiConversation[]          @relation("AiConversationUser")
  complianceControlsOwned ComplianceControl[]      @relation("ComplianceControlOwner")
  complianceEvidenceAdded ComplianceEvidence[]     @relation("ComplianceEvidenceAddedBy")
  complianceGapsOwned    ComplianceGap[]           @relation("ComplianceGapOwner")

  @@index([role])
  @@index([isActive])
  @@index([providerId])
  @@map("users")
}

model ProviderType {
  id               String    @id @default(uuid())
  name             String    @unique
  abbreviation     String    @unique
  isActive         Boolean   @default(true) @map("is_active")
  requiresEcfmg    Boolean   @default(false) @map("requires_ecfmg")
  requiresDea      Boolean   @default(false) @map("requires_dea")
  requiresBoards   Boolean   @default(false) @map("requires_boards")
  boardType        String?   @map("board_type")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  providers            Provider[]            @relation("ProviderTypeProviders")
  documentRequirements DocumentRequirement[] @relation("ProviderTypeDocReqs")

  @@map("provider_types")
}

model Provider {
  id                   String         @id @default(uuid())
  status               ProviderStatus @default(INVITED)
  providerTypeId       String         @map("provider_type_id")
  assignedSpecialistId String?        @map("assigned_specialist_id")
  legalFirstName       String         @map("legal_first_name")
  legalMiddleName      String?        @map("legal_middle_name")
  legalLastName        String         @map("legal_last_name")
  preferredName        String?        @map("preferred_name")
  dateOfBirth          String?        @map("date_of_birth") // encrypted AES-256
  ssn                  String?        // encrypted AES-256
  gender               String?
  languagesSpoken      String[]       @map("languages_spoken")
  npi                  String?        @unique
  deaNumber            String?        @map("dea_number")
  caqhId               String?        @map("caqh_id")
  icimsId              String?        @map("icims_id")
  medicarePtan         String?        @map("medicare_ptan")
  medicaidId           String?        @map("medicaid_id")
  inviteSentAt         DateTime?      @map("invite_sent_at")
  inviteToken          String?        @map("invite_token")
  inviteTokenExpiresAt DateTime?      @map("invite_token_expires_at")
  applicationStartedAt DateTime?      @map("application_started_at")
  applicationSubmittedAt DateTime?    @map("application_submitted_at")
  committeeReadyAt     DateTime?      @map("committee_ready_at")
  approvedAt           DateTime?      @map("approved_at")
  approvalSessionId    String?        @map("approval_session_id")
  approvedBy           String?        @map("approved_by")
  denialReason         String?        @map("denial_reason")
  notes                String?

  // COI / Malpractice tracking
  coiStatus            CoiStatus?     @map("coi_status")
  coiBrokerName        String?        @map("coi_broker_name")
  coiRequestedDate     DateTime?      @map("coi_requested_date")
  coiObtainedDate      DateTime?      @map("coi_obtained_date")
  coiExpirationDate    DateTime?      @map("coi_expiration_date")

  // Onsite meeting tracking
  onsiteMeetingStatus  OnsiteMeetingStatus? @map("onsite_meeting_status")
  onsiteMeetingDate    DateTime?      @map("onsite_meeting_date")
  onsiteMeetingNotes   String?        @map("onsite_meeting_notes")

  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  createdById          String?        @map("created_by")
  updatedById          String?        @map("updated_by")

  // Relations
  providerType        ProviderType       @relation("ProviderTypeProviders", fields: [providerTypeId], references: [id])
  assignedSpecialist  User?              @relation("SpecialistAssignedProviders", fields: [assignedSpecialistId], references: [id])
  approvalUser        User?              @relation("ApprovedByUser", fields: [approvedBy], references: [id])
  approvalSession     CommitteeSession?  @relation("ApprovalSession", fields: [approvalSessionId], references: [id])
  userAccount         User[]             @relation("UserLinkedProvider")
  profile             ProviderProfile?   @relation("ProviderProfile")
  licenses            License[]          @relation("ProviderLicenses")
  documents           Document[]         @relation("ProviderDocuments")
  checklistItems      ChecklistItem[]    @relation("ProviderChecklist")
  botRuns             BotRun[]           @relation("ProviderBotRuns")
  verificationRecords VerificationRecord[] @relation("ProviderVerifications")
  tasks               Task[]             @relation("ProviderTasks")
  communications      Communication[]    @relation("ProviderCommunications")
  enrollments         Enrollment[]       @relation("ProviderEnrollments")
  expirables          Expirable[]        @relation("ProviderExpirables")
  sanctionsChecks     SanctionsCheck[]   @relation("ProviderSanctions")
  npdbRecords         NPDBRecord[]       @relation("ProviderNpdb")
  hospitalPrivileges  HospitalPrivilege[] @relation("ProviderHospitalPrivileges")
  medicaidEnrollments MedicaidEnrollment[] @relation("ProviderMedicaid")
  committeeEntries    CommitteeProvider[] @relation("ProviderCommitteeEntries")
  auditLogs           AuditLog[]         @relation("ProviderAuditLogs")
  recredentialingCycles RecredentialingCycle[] @relation("ProviderRecredentialingCycles")
  workHistoryVerifications WorkHistoryVerification[] @relation("ProviderWorkHistoryVerifications")
  professionalReferences  ProfessionalReference[] @relation("ProviderProfessionalReferences")
  practiceEvaluations     PracticeEvaluation[] @relation("ProviderEvaluations")
  peerReviewMinutes       PeerReviewMinute[]   @relation("PeerReviewMinuteProvider")
  aiDecisionLogs          AiDecisionLog[]      @relation("AiDecisionLogProvider")
  botExceptionVerdicts    BotExceptionVerdict[] @relation("ProviderBotExceptionVerdicts")
  fsmbPdcSubscription     FsmbPdcSubscription?  @relation("ProviderFsmbPdcSubscription")
  fsmbPdcEvents           FsmbPdcEvent[]        @relation("ProviderFsmbPdcEvents")
  supervisionAttestations SupervisionAttestation[] @relation("ProviderSupervisionAttestations")
  cmeCredits              CmeCredit[]        @relation("ProviderCmeCredits")
  monitoringAlerts        MonitoringAlert[]  @relation("ProviderMonitoringAlerts")
  aiConversations         AiConversation[]   @relation("AiConversationProvider")
  malpracticeVerifications MalpracticeVerification[] @relation("ProviderMalpracticeVerifications")
  telehealthPlatformCerts TelehealthPlatformCert[] @relation("ProviderTelehealthPlatformCerts")
  directoryPractitionerRoles DirectoryPractitionerRole[] @relation("ProviderDirectoryRoles")

  // Phase 1: initial approval date for recredentialing cycle calculation
  initialApprovalDate DateTime? @map("initial_approval_date")

  @@index([status])
  @@index([providerTypeId])
  @@index([assignedSpecialistId])
  @@index([legalLastName])
  @@index([inviteToken])
  @@index([caqhId])
  @@index([icimsId])
  @@index([approvedAt])
  @@index([createdAt])
  @@map("providers")
}

model ProviderProfile {
  id                    String   @id @default(uuid())
  providerId            String   @unique @map("provider_id")
  homeAddressLine1      String?  @map("home_address_line1") // encrypted
  homeAddressLine2      String?  @map("home_address_line2") // encrypted
  homeCity              String?  @map("home_city") // encrypted
  homeState             String?  @map("home_state") // encrypted
  homeZip               String?  @map("home_zip") // encrypted
  homePhone             String?  @map("home_phone") // encrypted
  mobilePhone           String?  @map("mobile_phone")
  personalEmail         String?  @map("personal_email")
  emergencyContactName  String?  @map("emergency_contact_name")
  emergencyContactPhone String?  @map("emergency_contact_phone")
  ecfmgNumber           String?  @map("ecfmg_number")
  medicalSchoolName     String?  @map("medical_school_name")
  medicalSchoolCountry  String?  @map("medical_school_country")
  graduationYear        Int?     @map("graduation_year")
  specialtyPrimary      String?  @map("specialty_primary")
  specialtySecondary    String?  @map("specialty_secondary")
  hireDate              DateTime? @map("hire_date")
  startDate             DateTime? @map("start_date")
  facilityAssignment    String?  @map("facility_assignment")
  department            String?
  jobTitle              String?  @map("job_title")
  caqhDataSnapshot      Json?    @map("caqh_data_snapshot")
  icimsDataSnapshot     Json?    @map("icims_data_snapshot")

  // ── P1 Gap #14: CAQH ProView 2026 alignment ────────────────────────────
  // CAQH requires re-attestation every 120 days. Active-site enforcement
  // means the org (Essen) must be designated as an active practice
  // location, not merely a "viewer". The Groups module surfaces group
  // affiliations the provider has linked to in CAQH.
  caqhProfileStatus       String?   @map("caqh_profile_status")
  caqhAttestationDate     DateTime? @map("caqh_attestation_date")
  caqhNextReattestDue     DateTime? @map("caqh_next_reattest_due")
  caqhEssenIsActiveSite   Boolean?  @map("caqh_essen_active_site")
  caqhGroupAffiliations   Json?     @map("caqh_group_affiliations")
  caqhLastReminderSentAt  DateTime? @map("caqh_last_reminder_sent_at")
  caqhSyncedAt            DateTime? @map("caqh_synced_at")

  // Malpractice carrier verification (Gap #13)
  malpracticeCarrier         String?   @map("malpractice_carrier")
  malpracticePolicyNumber    String?   @map("malpractice_policy_number")
  malpracticeCoverageAmount  String?   @map("malpractice_coverage_amount")
  malpracticeExpDate         DateTime? @map("malpractice_exp_date")
  carrierVerificationStatus  String?   @map("carrier_verification_status")
  carrierVerificationDate    DateTime? @map("carrier_verification_date")

  // Telehealth credentialing (Gap #30)
  teleHealthPlatform       String?   @map("telehealth_platform")
  teleHealthTrainingDate   DateTime? @map("telehealth_training_date")
  teleHealthCertified      Boolean   @default(false) @map("telehealth_certified")
  teleHealthStates         String[]  @map("telehealth_states")

  // P1 Gap #15 — IMLC (Interstate Medical Licensure Compact) eligibility.
  // Captured separately because IMLC introduces a "letter of qualification"
  // (LoQ) issued by the SPL (State of Principal License) which then expedites
  // licensure in any other IMLC member state. Tracking the LoQ + member-state
  // grants is the only way to honestly compute multi-state telehealth coverage.
  imlcEligible             Boolean?  @map("imlc_eligible")
  imlcSpl                  String?   @map("imlc_spl") // 2-letter state code
  imlcLoqIssuedDate        DateTime? @map("imlc_loq_issued_date")
  imlcLoqExpiresAt         DateTime? @map("imlc_loq_expires_at")
  imlcLoqDocumentBlobUrl   String?   @map("imlc_loq_document_blob_url")
  imlcMemberStatesGranted  String[]  @map("imlc_member_states_granted")

  // ── P3 Gap #22 — Behavioral health specialty path ─────────────────────
  // NUCC taxonomy code (e.g. 101YM0800X = Mental Health Counselor).
  // Captured here so payer-roster and BCBS fast-track logic can identify
  // behavioral-health practitioners without scraping specialty strings.
  nuccTaxonomyPrimary       String?  @map("nucc_taxonomy_primary")
  nuccTaxonomySecondary     String[] @map("nucc_taxonomy_secondary")
  isBehavioralHealth        Boolean  @default(false) @map("is_behavioral_health")
  // Provisionally-licensed flag — when true, the provider must have a
  // current SupervisionAttestation on file with hours/supervisor logged.
  isProvisionallyLicensed   Boolean  @default(false) @map("is_provisionally_licensed")
  provisionalLicenseExpires DateTime? @map("provisional_license_expires")
  // BCBS fast-track tracking. Anthem/BCBS offers a behavioral-health
  // expedited credentialing track for under-served specialties; we track
  // submission + status here.
  bcbsFastTrackEligible     Boolean  @default(false) @map("bcbs_fast_track_eligible")
  bcbsFastTrackSubmittedAt  DateTime? @map("bcbs_fast_track_submitted_at")
  bcbsFastTrackStatus       String?  @map("bcbs_fast_track_status")
  bcbsFastTrackRefId        String?  @map("bcbs_fast_track_ref_id")

  // Demographics for NCQA (Gap #14)
  race      String?
  ethnicity String?

  // NCQA 2026 application standard — non-discrimination disclosure must be
  // explicitly acknowledged by the practitioner during initial credentialing
  // and recredentialing. We capture both the acknowledgment timestamp and
  // the disclosure version the provider saw, so future revisions don't
  // invalidate prior signatures.
  nonDiscriminationAckAt      DateTime? @map("non_discrimination_ack_at")
  nonDiscriminationAckVersion String?   @map("non_discrimination_ack_version")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  provider Provider @relation("ProviderProfile", fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_profiles")
}

model DocumentRequirement {
  id                   String          @id @default(uuid())
  providerTypeId       String          @map("provider_type_id")
  documentType         DocumentType    @map("document_type")
  requirement          RequirementType
  conditionDescription String?         @map("condition_description")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  providerType ProviderType @relation("ProviderTypeDocReqs", fields: [providerTypeId], references: [id], onDelete: Cascade)

  @@unique([providerTypeId, documentType])
  @@map("document_requirements")
}

model License {
  id             String        @id @default(uuid())
  providerId     String        @map("provider_id")
  state          String
  licenseNumber  String        @map("license_number")
  licenseType    String        @map("license_type")
  status         LicenseStatus @default(ACTIVE)
  issueDate      DateTime?     @map("issue_date")
  expirationDate DateTime?     @map("expiration_date")
  isPrimary      Boolean       @default(false) @map("is_primary")
  source         LicenseSource @default(MANUAL)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  provider Provider @relation("ProviderLicenses", fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([state, licenseNumber])
  @@map("licenses")
}

model Document {
  id                   String         @id @default(uuid())
  providerId           String         @map("provider_id")
  documentType         DocumentType   @map("document_type")
  originalFilename     String         @map("original_filename")
  blobUrl              String         @map("blob_url")
  blobContainer        String         @map("blob_container")
  blobPath             String         @map("blob_path")
  fileSizeBytes        Int            @map("file_size_bytes")
  mimeType             String         @map("mime_type")
  uploadedById         String?        @map("uploaded_by") // nullable: providers can upload via magic-link without a User row
  uploaderType         String?        @map("uploader_type") // "STAFF" | "PROVIDER" | "BOT" | "SYSTEM"
  source               DocumentSource
  ocrStatus            OcrStatus      @default(PENDING) @map("ocr_status")
  ocrData              Json?          @map("ocr_data")
  ocrConfidence        Float?         @map("ocr_confidence")

  // AI document auto-classification (P1 Gap #8). When the uploader picks a
  // document type, the classifier still runs and stores its independent
  // suggestion so staff can spot mismatches (e.g., uploader picked
  // BOARD_CERTIFICATION but the file is clearly a DEA certificate). The
  // suggestion is advisory only — never overwrites documentType automatically.
  suggestedDocumentType DocumentType? @map("suggested_document_type")
  classifierConfidence  Float?        @map("classifier_confidence")
  classifierVersion     String?       @map("classifier_version")
  classifierReason      String?       @map("classifier_reason")
  isVerified           Boolean        @default(false) @map("is_verified")
  verificationRecordId String?        @map("verification_record_id")
  expirationDate       DateTime?      @map("expiration_date")
  isDeleted            Boolean        @default(false) @map("is_deleted")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  provider           Provider            @relation("ProviderDocuments", fields: [providerId], references: [id])
  uploadedBy         User?               @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  verificationRecord VerificationRecord? @relation("DocumentVerification", fields: [verificationRecordId], references: [id])
  checklistItems     ChecklistItem[]     @relation("ChecklistDocument")
  appointmentPrivileges HospitalPrivilege[] @relation("AppointmentLetterDoc")
  reappointmentPrivileges HospitalPrivilege[] @relation("ReappointmentLetterDoc")
  expirables         Expirable[]         @relation("ExpirableDocument")
  cmeCredits         CmeCredit[]         @relation("CmeCreditDocument")

  @@index([providerId])
  @@index([documentType])
  @@index([isDeleted])
  @@index([providerId, documentType])
  @@index([expirationDate])
  @@map("documents")
}

