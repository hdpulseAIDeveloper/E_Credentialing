{
  "name": "essen-credentialing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 6015",
    "dev:warm": "node scripts/dev/dev-with-warmup.mjs",
    "warm": "node scripts/dev/warm-routes.mjs",
    "build": "next build",
    "start": "next start -p 6015",
    "preview": "next build && next start -p 6015",
    "dev:worker": "tsx watch src/workers/index.ts",
    "build:worker": "tsc --project tsconfig.worker.json && tsc-alias --project tsconfig.worker.json",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:extras": "tsx prisma/seed-extras.ts",
    "db:seed:all": "tsx prisma/seed.ts && tsx prisma/seed-extras.ts",
    "db:studio": "prisma studio",
    "bot:headed": "tsx src/workers/bot-runner.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "qa:inventory": "tsx scripts/qa/build-all-inventories.ts",
    "qa:coverage": "tsx scripts/qa/check-coverage.ts",
    "qa:coverage:report": "tsx scripts/qa/check-coverage.ts --report",
    "qa:smoke": "playwright test tests/e2e/pillar-a-smoke",
    "qa:rbac": "playwright test tests/e2e/pillar-b-rbac",
    "qa:phi": "playwright test tests/e2e/pillar-c-phi",
    "qa:flows": "playwright test tests/e2e/pillar-d-flows",
    "qa:a11y": "playwright test tests/e2e/pillar-e-a11y",
    "qa:a11y:palette": "node scripts/qa/verify-palette-contrast.mjs",
    "qa:all": "tsx scripts/qa/run-all-pillars.ts"
  },
