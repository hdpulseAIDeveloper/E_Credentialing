# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/
build/
dist/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Prisma
# Migrations MUST be tracked in git — production uses `prisma migrate deploy`.
# Ignore only migration-generated ephemeral files.
prisma/migrations/**/*.tmp

# Local commit message scratch files (PowerShell heredoc workaround)
.git-commit-msg.tmp
.git-commit-msg.*.tmp

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code local settings (contains personal overrides — not for team)
.claude/settings.local.json

# Docker
docker-compose.override.yml

# Azure
*.pfx
*.pem

# Uploads / temp
tmp/
.tmp/
temp/
uploads/
tsconfig.tsbuildinfo

# QA / Playwright — auth state files contain real session cookies for
# seeded test users. They must NEVER be committed.
tests/e2e/.auth/

# QA / Playwright — raw run artefacts (videos, screenshots, HTML report)
# can balloon to GBs across runs. The SUMMARY.md and the JSON results
# (small, machine-readable, append-only per STANDARD §6) are tracked.
docs/qa/results/*/test-output/
docs/qa/results/*/playwright/
playwright-report/
test-results/
