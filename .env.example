# ESSEN Credentialing Platform — Environment Variables Template
# Copy to .env.local for development. Never commit .env.local or any file with real secrets.
#
# LOCAL DEV NOTE:
#   - PostgreSQL runs in localai-postgres-1 container (localai_default network)
#     Host access: localhost:5433  |  Container access: localai-postgres-1:5432
#   - Redis runs in the redis container (localai_default network)
#     Host access: localhost:6379  |  Container access: redis:6379

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:6015
NODE_ENV=development

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Development — use localai-postgres-1 container (password: testpostgrespass00)
DATABASE_URL=postgresql://postgres:testpostgrespass00@localai-postgres-1:5432/e_credentialing_db
# Production — shared Supabase container on supabase_network_hdpulse2000
# DATABASE_URL=postgresql://postgres:postgres@supabase_db_hdpulse2000:5432/e_credentialing_db

# =============================================================================
# Redis (BullMQ queue backing store)
# =============================================================================
# When running inside Docker (docker-compose.dev.yml):
REDIS_HOST=redis
REDIS_PORT=6379
# When running locally (npm run dev outside Docker):
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# Azure Active Directory (Staff SSO)
# =============================================================================
AZURE_AD_TENANT_ID=           # Essen's Azure AD tenant ID
AZURE_AD_CLIENT_ID=           # App registration client ID
AZURE_AD_CLIENT_SECRET=       # App registration client secret

# NextAuth.js
NEXTAUTH_URL=http://localhost:6015
NEXTAUTH_SECRET=              # Generate with: openssl rand -base64 32

# =============================================================================
# Azure Key Vault (All secrets for bots, APIs, credentials)
# =============================================================================
AZURE_KEY_VAULT_URL=          # https://{vault-name}.vault.azure.net/
# Local dev: authenticate with: az login  (uses your Azure CLI credentials)
# Container: uses Managed Identity automatically

# =============================================================================
# Azure Blob Storage (Document and bot output storage)
# =============================================================================
AZURE_BLOB_ACCOUNT_URL=       # https://{account}.blob.core.windows.net/
AZURE_BLOB_CONTAINER=essen-credentialing

# =============================================================================
# Azure AI Document Intelligence (OCR for credential documents)
# =============================================================================
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=

# =============================================================================
# Azure Communication Services (SMS outreach to providers)
# =============================================================================
AZURE_COMMUNICATION_SERVICES_ENDPOINT=

# =============================================================================
# Email (SendGrid)
# =============================================================================
SENDGRID_API_KEY=             # Retrieve from SendGrid dashboard
SENDGRID_FROM_EMAIL=cred_onboarding@essenmed.com

# =============================================================================
# PHI Encryption Key (AES-256-GCM — stored in Key Vault in production)
# =============================================================================
# For local dev only — generate a 32-byte key:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=               # 32-byte base64 key — NEVER commit a real value

# =============================================================================
# Audit log HMAC key (tamper-evident chain — stored in Key Vault in production)
# =============================================================================
# Required: 32+ character secret. Production refuses to start without it.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_HMAC_KEY=               # 32+ character secret — NEVER commit a real value

# =============================================================================
# Worker (BullMQ Bull Board monitoring dashboard)
# =============================================================================
BULL_BOARD_PORT=6025
WORKER_INTERNAL_URL=http://ecred-worker:6025   # internal Docker URL
NEXT_PUBLIC_WORKER_URL=http://localhost:6025    # browser-accessible URL for socket.io
